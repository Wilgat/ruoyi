#!/bin/sh

# ────────────────────────────────────────────────
#  ruoyi – version 1.0.2
#  One-command installer + launcher for RuoYi admin framework
#    • Installs itself if not present
#    • Installs SDKMAN! if missing
#    • Installs Java 21 (Temurin)
#    • Installs Maven 3.9.13
#    • Clones original RuoYi from yangzongzhuan/RuoYi
#    • Optional: MySQL install + DB setup (run as root: ruoyi mysql)
# ────────────────────────────────────────────────

VERSION="1.0.2"
APP=ruoyi
GITUSER=Wilgat
JAVA_MAIN_VER=21
JAVA_BRAND=Temurin
JAVA_ID=$JAVA_MAIN_VER-tem
MAVEN_VER=3.9.13
PORT=8080
BIND_IP=0.0.0.0
GIT_REPO="https://github.com/yangzongzhuan/RuoYi.git"
GITUSERCONTENT="https://raw.githubusercontent.com/$GITUSER/$APP/main/$APP"
PROJECT_DIR="$HOME/$APP"
DB_NAME="ry"
DB_USER="ruoyi"
SQL_SCRIPT_PATTERN="sql/ry_*.sql"  # more flexible

# Colors
if [ -t 1 ]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    GREEN='' YELLOW='' RED='' NC=''
fi

# ────────────────────────────────────────────────
# (installation path logic, helpers, install_self, show_help, argument parsing – unchanged from your version)
# ────────────────────────────────────────────────

# Only showing changed/improved main part below

# ────────────────────────────────────────────────
# Main payload
# ────────────────────────────────────────────────

echo ""
echo "=============================================================="
echo "  $APP v$VERSION – Java 21 + Maven + RuoYi setup"
echo "=============================================================="
echo ""

# ... (SDKMAN, Java, Maven installation – keep your code) ...

# 4. MySQL setup (only if mysql param and root)
if [ "$COMMAND" = "mysql" ]; then
    if ! command -v apt-get >/dev/null 2>&1; then
        echo "${RED}This script currently only supports Debian/Ubuntu for auto MySQL install.${NC}"
        echo "Please install MySQL manually and run 'ruoyi' without mysql param."
        exit 1
    fi

    echo "→ Installing MySQL server..."
    apt-get update -y && apt-get install -y mysql-server || {
        echo "${RED}MySQL installation failed${NC}"
        exit 1
    }

    echo "→ Running mysql_secure_installation (follow prompts)..."
    mysql_secure_installation

    echo ""
    echo "→ RuoYi database configuration"
    read -p "MySQL root password: " mysql_root_pass
    read -p "Database name [ry]: " db_name_input
    DB_NAME=${db_name_input:-ry}
    read -p "Database user [ruoyi]: " db_user_input
    DB_USER=${db_user_input:-ruoyi}
    read -s -p "Database password: " db_pass
    echo ""

    echo "→ Creating database and user..."
    mysql -u root -p"$mysql_root_pass" -e "CREATE DATABASE IF NOT EXISTS \`$DB_NAME\` CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;" || exit 1
    mysql -u root -p"$mysql_root_pass" -e "CREATE USER IF NOT EXISTS '$DB_USER'@'localhost' IDENTIFIED BY '$db_pass';" || exit 1
    mysql -u root -p"$mysql_root_pass" -e "GRANT ALL PRIVILEGES ON \`$DB_NAME\`.* TO '$DB_USER'@'localhost';" || exit 1
    mysql -u root -p"$mysql_root_pass" -e "FLUSH PRIVILEGES;"
fi

# 5. Clone & prepare RuoYi
echo ""
echo "→ Cloning RuoYi project..."
if [ -d "$PROJECT_DIR" ]; then
    echo "   Removing old project folder..."
    rm -rf "$PROJECT_DIR"
fi

git clone --depth 1 "$GIT_REPO" "$PROJECT_DIR" || {
    echo "${RED}Git clone failed – check network or repo URL${NC}"
    exit 1
}

cd "$PROJECT_DIR" || exit 1

# Force Java 21
echo "→ Setting Java version to 21 in pom.xml..."
sed -i 's|<java.version>.*</java.version>|<java.version>21</java.version>|g' pom.xml

# Update DB config if mysql mode was used
if [ "$COMMAND" = "mysql" ]; then
    CONFIG_FILE="ruoyi-admin/src/main/resources/application-druid.yml"
    if [ -f "$CONFIG_FILE" ]; then
        sed -i "s|url: jdbc:mysql://localhost:3306/ry|url: jdbc:mysql://localhost:3306/$DB_NAME|g" "$CONFIG_FILE"
        sed -i "s|username: root|username: $DB_USER|g" "$CONFIG_FILE"
        sed -i "s|password: password|password: $db_pass|g" "$CONFIG_FILE"
        echo "   Updated database config → $CONFIG_FILE"
    else
        echo "${YELLOW}Warning: $CONFIG_FILE not found – DB config not updated${NC}"
    fi

    # Run latest ry_*.sql
    SQL_FILE=$(ls sql/ry_*.sql 2>/dev/null | sort -r | head -n 1)
    if [ -n "$SQL_FILE" ]; then
        echo "→ Importing latest SQL: $SQL_FILE"
        mysql -u root -p"$mysql_root_pass" "$DB_NAME" < "$SQL_FILE" || {
            echo "${RED}SQL import failed${NC}"
            exit 1
        }
    else
        echo "${YELLOW}No ry_*.sql found – skipping DB initialization${NC}"
    fi
fi

# Optional: remove unused modules (comment out if you want full features)
echo "→ Removing optional modules (generator, quartz) for faster startup..."
rm -rf ruoyi-generator ruoyi-quartz 2>/dev/null || true

# 6. Build & run
echo ""
echo "→ Building RuoYi (this may take a few minutes)..."
mvn clean package -Dmaven.test.skip=true || {
    echo "${RED}Build failed${NC}"
    echo "Try manually: cd $PROJECT_DIR && mvn clean package -Dmaven.test.skip=true"
    exit 1
}

echo ""
echo "=============================================================="
echo "  RuoYi is starting..."
echo "  → URL: http://localhost:$PORT"
echo "  → Default login: admin / admin123"
echo "  → Press Ctrl+C to stop"
echo "=============================================================="
echo ""

# Run with SDKMAN Java if available
JAVA_CMD="$(sdk home java current)/bin/java"
if [ -x "$JAVA_CMD" ]; then
    "$JAVA_CMD" -jar ruoyi-admin/target/ruoyi-admin.jar
else
    java -jar ruoyi-admin/target/ruoyi-admin.jar
fi