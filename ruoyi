#!/bin/sh

# ────────────────────────────────────────────────
#  ruoyi – version 1.0.3
#  One-command installer + launcher for RuoYi admin framework
#    • Installs itself if not present
#    • Installs SDKMAN! if missing
#    • Installs Java 21 (Temurin)
#    • Installs Maven 3.9.13
#    • Clones original RuoYi (yangzongzhuan/RuoYi)
#    • Optional MySQL + DB setup (sudo ruoyi mysql)
# ────────────────────────────────────────────────

VERSION="1.0.3"
APP=ruoyi
GITUSER=Wilgat
JAVA_MAIN_VER=21
JAVA_BRAND=Temurin
JAVA_ID=$JAVA_MAIN_VER-tem
MAVEN_VER=3.9.13
PORT=8080
BIND_IP=0.0.0.0
GIT_REPO="https://github.com/yangzongzhuan/RuoYi.git"
GITUSERCONTENT=https://raw.githubusercontent.com/$GITUSER/$APP/main/$APP
PROJECT_DIR="$HOME/$APP"
DB_NAME="ry"
DB_USER="ruoyi"

# Colors
if [ -t 1 ]; then
    GREEN='\033[0;32m'
    YELLOW='\033[1;33m'
    RED='\033[0;31m'
    NC='\033[0m'
else
    GREEN='' YELLOW='' RED='' NC=''
fi

# ────────────────────────────────────────────────
# Installation path logic (unchanged)
# ────────────────────────────────────────────────

if [ "$(id -u)" -eq 0 ]; then
    INSTALL_DIR="/usr/local/bin"
    INSTALL_PATH="$INSTALL_DIR/$APP"
    NEEDS_SUDO=false
else
    INSTALL_DIR="${HOME}/.local/bin"
    INSTALL_PATH="$INSTALL_DIR/$APP"
    NEEDS_SUDO=true
fi

# ────────────────────────────────────────────────
# Helpers (unchanged)
# ────────────────────────────────────────────────

is_installed() {
    [ -f "$INSTALL_PATH" ] && [ -x "$INSTALL_PATH" ]
}

in_path() {
    case ":${PATH}:" in
        *:"${INSTALL_DIR}":*) return 0 ;;
        *) return 1 ;;
    esac
}

add_to_bashrc() {
    local bashrc="${HOME}/.bashrc"
    local line="export PATH=\"\$HOME/.local/bin:\$PATH\""

    if [ -f "$bashrc" ] && grep -qF "$line" "$bashrc" 2>/dev/null; then
        return
    fi

    echo "" >> "$bashrc"
    echo "# Added by $APP installer" >> "$bashrc"
    echo "$line" >> "$bashrc"
    echo "${YELLOW}→ Added ~/.local/bin to PATH in ~/.bashrc${NC}"
}

# ────────────────────────────────────────────────
# Self-install logic (unchanged)
# ────────────────────────────────────────────────

install_self() {
    echo ""
    echo "${YELLOW}$APP not found → installing...${NC}"
    echo ""

    if $NEEDS_SUDO; then
        echo "Recommended install command (use bash explicitly):"
        echo "  ${GREEN}sudo curl -fsSL $GITUSERCONTENT | sudo bash${NC}"
    else
        echo "Recommended install command (use bash explicitly):"
        echo "  ${GREEN}curl -fsSL $GITUSERCONTENT | bash${NC}"
    fi

    echo ""

    mkdir -p "$INSTALL_DIR" 2>/dev/null || {
        echo "${RED}Cannot create directory $INSTALL_DIR${NC}" >&2
        exit 1
    }

    TMP_SCRIPT="/tmp/$APP_$$.sh"
    if ! curl -fsSL "$GITUSERCONTENT" -o "$TMP_SCRIPT"; then
        echo "${RED}Failed to download installer${NC}" >&2
        rm -f "$TMP_SCRIPT" 2>/dev/null
        exit 1
    fi

    chmod 755 "$TMP_SCRIPT" || {
        echo "${RED}chmod failed${NC}" >&2
        rm -f "$TMP_SCRIPT"
        exit 1
    }

    if cp "$TMP_SCRIPT" "$INSTALL_PATH" 2>/dev/null; then
        echo "${GREEN}Installed to $INSTALL_PATH${NC}"
        rm -f "$TMP_SCRIPT"
        
        if ! $NEEDS_SUDO && ! in_path; then
            add_to_bashrc
            echo ""
            echo "${YELLOW}→ ~/.local/bin was added to ~/.bashrc${NC}"
            echo "  To use '$APP' immediately in this session run:"
            echo "    ${GREEN}. ~/.bashrc${NC}"
            echo "  (or open a new terminal)"
            echo "  Continuing in current session anyway..."
        fi

        echo "${GREEN}Proceeding to setup SDKMAN + Java $JAVA_MAIN_VER + Maven + RuoYi...${NC}"
        echo ""
    else
        echo "${RED}Failed to install to $INSTALL_PATH${NC}" >&2
        echo "  Permission denied? Try with sudo."
        rm -f "$TMP_SCRIPT"
        exit 1
    fi
}

# ────────────────────────────────────────────────
# Help (unchanged)
# ────────────────────────────────────────────────

show_help() {
    cat << 'EOF'
$APP – version $VERSION

One-command RuoYi framework setup

Usage:
  $APP               Setup tools + clone + build + run RuoYi
  $APP mysql         (sudo) Install MySQL + create DB + import SQL
  $APP help          Show this help
  $APP version       Show version

EOF
}

# ────────────────────────────────────────────────
# Argument parsing (unchanged)
# ────────────────────────────────────────────────

COMMAND="run"

while [ $# -gt 0 ]; do
    case "$1" in
        version) COMMAND="version"; shift ;;
        help)    COMMAND="help";    shift ;;
        mysql)   COMMAND="mysql";   shift ;;
        *)       echo "${RED}Unknown argument: $1${NC}" >&2
                 echo "Try: $APP help"
                 exit 1 ;;
    esac
done

if ! is_installed; then
    install_self
fi

case "$COMMAND" in
    version) echo "$APP version $VERSION"; exit 0 ;;
    help)    show_help; exit 0 ;;
    run)     : ;;
    mysql)
        if [ "$(id -u)" -ne 0 ]; then
            echo "${RED}Must run as root/sudo for mysql mode${NC}" >&2
            exit 1
        fi
        ;;
    *)       echo "${RED}Invalid command${NC}" >&2; exit 1 ;;
esac

# ────────────────────────────────────────────────
# Main logic
# ────────────────────────────────────────────────

echo ""
echo "=============================================================="
echo "  $APP v$VERSION – Java 21 + Maven + RuoYi"
echo "=============================================================="
echo ""

# SDKMAN
echo "→ Checking SDKMAN..."
if [ -d "$HOME/.sdkman" ] && command -v sdk >/dev/null 2>&1; then
    echo "   Already installed."
else
    echo "   Installing SDKMAN..."
    curl -s "https://get.sdkman.io" | bash
    [ $? -ne 0 ] && { echo "${RED}SDKMAN install failed${NC}"; exit 1; }

    echo "   Loading SDKMAN..."
    [ -s "$HOME/.sdkman/bin/sdkman-init.sh" ] && . "$HOME/.sdkman/bin/sdkman-init.sh"
fi

if ! command -v sdk >/dev/null 2>&1; then
    echo "${YELLOW}sdk still not available — run . ~/.sdkman/bin/sdkman-init.sh or open new terminal${NC}"
    exit 1
fi

echo "   SDKMAN ready."
sdk version | head -n 1

# Java 21
echo ""
echo "→ Installing Java 21 ($JAVA_BRAND)..."
sdk install java $JAVA_ID </dev/null || { echo "${RED}Java install failed${NC}"; exit 1; }
sdk default java $JAVA_ID >/dev/null 2>&1
sdk use java $JAVA_ID >/dev/null 2>&1 || true

JAVA_CMD="$(sdk home java current)/bin/java"
"$JAVA_CMD" -version 2>&1 | head -n 1 || { echo "${RED}java not found${NC}"; exit 1; }

# Maven
echo ""
echo "→ Installing Maven $MAVEN_VER..."
sdk install maven $MAVEN_VER </dev/null || { echo "${RED}Maven install failed${NC}"; exit 1; }
sdk default maven $MAVEN_VER >/dev/null 2>&1
sdk use maven $MAVEN_VER >/dev/null 2>&1 || true
mvn --version | head -n 3 || { echo "${RED}mvn not found${NC}"; exit 1; }

# MySQL mode (if requested)
if [ "$COMMAND" = "mysql" ]; then
    echo "→ Installing MySQL (Ubuntu/Debian assumed)..."
    apt-get update -y && apt-get install -y mysql-server || exit 1
    mysql_secure_installation

    echo "→ RuoYi DB setup"
    read -p "MySQL root password: " mysql_root_pass
    read -p "DB name [ry]: " db_name; DB_NAME=${db_name:-ry}
    read -p "DB user [ruoyi]: " db_user; DB_USER=${db_user:-ruoyi}
    read -s -p "DB password: " db_pass; echo ""

    mysql -u root -p"$mysql_root_pass" -e "CREATE DATABASE IF NOT EXISTS \`$DB_NAME\` CHARACTER SET utf8mb4 COLLATE utf8mb4_general_ci;"
    mysql -u root -p"$mysql_root_pass" -e "CREATE USER IF NOT EXISTS '$DB_USER'@'localhost' IDENTIFIED BY '$db_pass';"
    mysql -u root -p"$mysql_root_pass" -e "GRANT ALL ON \`$DB_NAME\`.* TO '$DB_USER'@'localhost'; FLUSH PRIVILEGES;"
fi

# Clone RuoYi
echo ""
echo "→ Cloning RuoYi..."
[ -d "$PROJECT_DIR" ] && { echo "   Removing old folder..."; rm -rf "$PROJECT_DIR"; }
git clone --depth 1 "$GIT_REPO" "$PROJECT_DIR" || exit 1
cd "$PROJECT_DIR" || exit 1

# Update to Java 21
sed -i 's|<java.version>.*</java.version>|<java.version>21</java.version>|g' pom.xml

# Apply DB config if mysql mode
if [ "$COMMAND" = "mysql" ]; then
    CONFIG="ruoyi-admin/src/main/resources/application-druid.yml"
    [ -f "$CONFIG" ] && {
        sed -i "s|url:.*3306/ry|url: jdbc:mysql://localhost:3306/$DB_NAME|g" "$CONFIG"
        sed -i "s|username: root|username: $DB_USER|g" "$CONFIG"
        sed -i "s|password:.*|password: $db_pass|g" "$CONFIG"
        echo "   DB config updated"
    }
fi

# Import SQL if mysql mode
if [ "$COMMAND" = "mysql" ]; then
    SQL_FILE=$(ls sql/ry_*.sql 2>/dev/null | sort -r | head -n 1)
    [ -n "$SQL_FILE" ] && {
        echo "→ Importing $SQL_FILE..."
        mysql -u root -p"$mysql_root_pass" "$DB_NAME" < "$SQL_FILE" || echo "${YELLOW}SQL import warning${NC}"
    }
fi

# Optional cleanup
echo "→ Removing optional modules..."
rm -rf ruoyi-generator ruoyi-quartz 2>/dev/null || true

# Build & run
echo ""
echo "→ Building..."
mvn clean package -Dmaven.test.skip=true || exit 1

echo ""
echo "=============================================================="
echo "  RuoYi starting → http://localhost:$PORT"
echo "  Default: admin / admin123"
echo "=============================================================="

"$JAVA_CMD" -jar ruoyi-admin/target/ruoyi-admin.jar